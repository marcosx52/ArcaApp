generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserStatus {
  ACTIVE
  INVITED_FUTURE
  DISABLED
}

enum CompanyOnboardingStatus {
  DRAFT
  PENDING_TAX_SETUP
  READY_FOR_HOMOLOGATION
  READY_FOR_PRODUCTION
  SUSPENDED
}

enum CompanyRole {
  OWNER
  ADMIN
  OPERATOR
  VIEWER
}

enum ArcaEnvironment {
  TESTING
  PRODUCTION
}

enum ConfigStatus {
  INCOMPLETE
  PENDING_VALIDATION
  VALIDATED
  BLOCKED
}

enum CertificateStatus {
  UPLOADED
  VALID
  EXPIRED
  INVALID
  REVOKED
}

enum SalesPointStatus {
  ACTIVE
  INACTIVE
  BLOCKED
}

enum CustomerType {
  INDIVIDUAL
  COMPANY
  FINAL_CONSUMER_PROFILE
}

enum DocumentType {
  CUIT
  CUIL
  DNI
  SIN_DOCUMENTO
}

enum ItemType {
  PRODUCT
  SERVICE
}

enum TaxTreatment {
  GRAVADO
  EXENTO
  NO_ALCANZADO
}

enum InvoiceKind {
  INVOICE
  CREDIT_NOTE
  DEBIT_NOTE_FUTURE
}

enum InvoiceLetter {
  A
  B
  C
  M
  E_FUTURE
}

enum ConceptType {
  PRODUCTS
  SERVICES
  PRODUCTS_AND_SERVICES
}

enum InvoiceStatus {
  DRAFT
  READY
  SENDING
  ISSUED
  FAILED
  CANCELLED_LOGICALLY
}

enum ArcaInvoiceStatus {
  NOT_SENT
  ACCEPTED
  REJECTED
  PARTIAL_WARNING
  UNKNOWN_NEEDS_CHECK
}

enum InvoiceEventType {
  DRAFT_CREATED
  DRAFT_UPDATED
  VALIDATION_PASSED
  VALIDATION_FAILED
  EMISSION_REQUESTED
  EMISSION_SENT
  EMISSION_ACCEPTED
  EMISSION_REJECTED
  PDF_GENERATED
  MANUALLY_MARKED_FOR_REVIEW
}

enum InvoiceRelationType {
  CREDITS
  DEBITS_FUTURE
  REFERENCES
}

enum ArcaAuthSessionStatus {
  ACTIVE
  EXPIRED
  INVALID
  REVOKED
}

enum ArcaRequestType {
  WSAA_LOGIN
  INVOICE_EMIT
  INVOICE_CONSULT
  VOUCHER_LAST_NUMBER_CHECK
  OTHER
}

enum IntegrationResult {
  SUCCESS
  REJECTED
  TIMEOUT
  TRANSPORT_ERROR
  PARSING_ERROR
  UNKNOWN
}

enum GeneratedDocumentType {
  PDF_INVOICE
  QR_IMAGE_FUTURE
  TECHNICAL_REPORT_FUTURE
}

enum DocumentGenerationStatus {
  PENDING
  GENERATED
  FAILED
}

model User {
  id              String         @id @default(cuid())
  email           String         @unique
  passwordHash    String
  fullName        String
  status          UserStatus     @default(ACTIVE)
  lastLoginAt     DateTime?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  companies       UserCompany[]
  createdInvoices Invoice[]      @relation("InvoiceCreatedBy")
  invoiceEvents   InvoiceEvent[] @relation("InvoiceEventActor")
}

model Company {
  id               String                  @id @default(cuid())
  legalName        String
  tradeName        String?
  cuit             String                  @unique
  taxProfile       String
  vatCondition     String
  addressLine      String?
  city             String?
  province         String?
  country          String?                 @default("AR")
  email            String?
  phone            String?
  onboardingStatus CompanyOnboardingStatus @default(DRAFT)
  createdAt        DateTime                @default(now())
  updatedAt        DateTime                @updatedAt

  users            UserCompany[]
  taxConfigs       CompanyTaxConfig[]
  certificates     CompanyCertificate[]
  salesPoints      SalesPoint[]
  customers        Customer[]
  products         Product[]
  invoices         Invoice[]
  invoiceEvents    InvoiceEvent[]
  arcaAuthSessions ArcaAuthSession[]
  arcaRequestLogs  ArcaRequestLog[]
  documents        GeneratedDocument[]
}

model UserCompany {
  id        String      @id @default(cuid())
  userId    String
  companyId String
  role      CompanyRole @default(OWNER)
  isDefault Boolean     @default(false)
  createdAt DateTime    @default(now())

  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  company   Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([userId, companyId])
  @@index([companyId])
}

model CompanyTaxConfig {
  id                  String          @id @default(cuid())
  companyId           String
  environment         ArcaEnvironment
  arcaServiceType     String?
  productionEnabled   Boolean         @default(false)
  homologationEnabled Boolean         @default(false)
  nextInvoiceFlowMode String?
  defaultCurrency     String?         @default("PES")
  defaultInvoiceTypeC String?
  defaultInvoiceTypeB String?
  configStatus        ConfigStatus    @default(INCOMPLETE)
  notes               String?
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt

  company             Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId, environment])
}

model CompanyCertificate {
  id                    String            @id @default(cuid())
  companyId             String
  environment           ArcaEnvironment
  certificateAlias      String?
  certificateStorageKey String
  privateKeyStorageKey  String
  certificateStatus     CertificateStatus @default(UPLOADED)
  validFrom             DateTime?
  validTo               DateTime?
  lastTestedAt          DateTime?
  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt

  company               Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId, environment])
}

model SalesPoint {
  id                   String           @id @default(cuid())
  companyId            String
  posNumber            Int
  name                 String?
  arcaPosType          String?
  enabledForTesting    Boolean          @default(false)
  enabledForProduction Boolean          @default(false)
  status               SalesPointStatus @default(ACTIVE)
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt

  company              Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  invoices             Invoice[]

  @@unique([companyId, posNumber])
  @@index([companyId, status])
}

model Customer {
  id             String       @id @default(cuid())
  companyId      String
  customerType   CustomerType
  legalName      String
  documentType   DocumentType
  documentNumber String
  taxCondition   String
  email          String?
  phone          String?
  addressLine    String?
  city           String?
  province       String?
  notes          String?
  isFrequent     Boolean      @default(false)
  isActive       Boolean      @default(true)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  company        Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  invoices       Invoice[]

  @@index([companyId, legalName])
  @@index([companyId, documentNumber])
  @@index([companyId, isActive])
}

model Product {
  id             String       @id @default(cuid())
  companyId      String
  itemType       ItemType
  code           String?
  name           String
  description    String?
  unitName       String?
  referencePrice Decimal?     @db.Decimal(18, 2)
  taxTreatment   TaxTreatment?
  vatRate        Decimal?     @db.Decimal(5, 2)
  isActive       Boolean      @default(true)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  company        Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  invoiceItems   InvoiceItem[]

  @@index([companyId, name])
  @@index([companyId, isActive])
}

model Invoice {
  id                      String             @id @default(cuid())
  companyId               String
  salesPointId            String?
  customerId              String?
  createdByUserId         String
  invoiceKind             InvoiceKind
  invoiceLetter           InvoiceLetter
  invoiceNumber           Int?
  fullInvoiceCode         String?
  conceptType             ConceptType?
  currencyCode            String?            @default("PES")
  currencyRate            Decimal?           @db.Decimal(18, 6)
  issueDate               DateTime?
  serviceFromDate         DateTime?
  serviceToDate           DateTime?
  dueDate                 DateTime?
  subtotalAmount          Decimal            @default(0) @db.Decimal(18, 2)
  taxAmount               Decimal            @default(0) @db.Decimal(18, 2)
  otherTaxesAmount        Decimal            @default(0) @db.Decimal(18, 2)
  totalAmount             Decimal            @default(0) @db.Decimal(18, 2)
  status                  InvoiceStatus      @default(DRAFT)
  arcaStatus              ArcaInvoiceStatus  @default(NOT_SENT)
  cae                     String?
  caeDueDate              DateTime?
  arcaResultCode          String?
  arcaObservationsSummary String?
  pdfDocumentId           String?
  emittedAt               DateTime?
  createdAt               DateTime           @default(now())
  updatedAt               DateTime           @updatedAt

  company                 Company            @relation(fields: [companyId], references: [id], onDelete: Cascade)
  salesPoint              SalesPoint?        @relation(fields: [salesPointId], references: [id], onDelete: SetNull)
  customer                Customer?          @relation(fields: [customerId], references: [id], onDelete: SetNull)
  createdByUser           User               @relation("InvoiceCreatedBy", fields: [createdByUserId], references: [id], onDelete: Restrict)
  items                   InvoiceItem[]
  events                  InvoiceEvent[]
  sourceRelations         InvoiceRelation[]  @relation("InvoiceRelationSource")
  targetRelations         InvoiceRelation[]  @relation("InvoiceRelationTarget")
  arcaLogs                ArcaRequestLog[]
  documents               GeneratedDocument[] @relation("InvoiceDocuments")
  pdfDocument             GeneratedDocument? @relation("InvoiceMainPdf", fields: [pdfDocumentId], references: [id], onDelete: SetNull)

  @@index([companyId, status])
  @@index([companyId, issueDate])
  @@index([companyId, invoiceNumber])
  @@index([companyId, customerId])
  @@index([companyId, arcaStatus])
}

model InvoiceItem {
  id             String    @id @default(cuid())
  invoiceId      String
  productId      String?
  lineOrder      Int
  itemCode       String?
  description    String
  quantity       Decimal   @default(1) @db.Decimal(18, 3)
  unitPrice      Decimal   @default(0) @db.Decimal(18, 2)
  discountAmount Decimal   @default(0) @db.Decimal(18, 2)
  subtotalAmount Decimal   @default(0) @db.Decimal(18, 2)
  vatRate        Decimal?  @db.Decimal(5, 2)
  vatAmount      Decimal   @default(0) @db.Decimal(18, 2)
  totalAmount    Decimal   @default(0) @db.Decimal(18, 2)
  metadata       Json?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  invoice        Invoice   @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  product        Product?  @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@index([invoiceId, lineOrder])
}

model InvoiceEvent {
  id              String           @id @default(cuid())
  invoiceId       String
  companyId       String
  actorUserId     String?
  eventType       InvoiceEventType
  previousStatus  InvoiceStatus?
  newStatus       InvoiceStatus?
  message         String?
  payloadSnapshot Json?
  createdAt       DateTime         @default(now())

  invoice         Invoice          @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  company         Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  actorUser       User?            @relation("InvoiceEventActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([invoiceId, createdAt])
  @@index([companyId, createdAt])
}

model InvoiceRelation {
  id              String              @id @default(cuid())
  sourceInvoiceId String
  targetInvoiceId String
  relationType    InvoiceRelationType
  createdAt       DateTime            @default(now())

  sourceInvoice   Invoice             @relation("InvoiceRelationSource", fields: [sourceInvoiceId], references: [id], onDelete: Cascade)
  targetInvoice   Invoice             @relation("InvoiceRelationTarget", fields: [targetInvoiceId], references: [id], onDelete: Cascade)

  @@index([sourceInvoiceId])
  @@index([targetInvoiceId])
}

model ArcaAuthSession {
  id          String                @id @default(cuid())
  companyId   String
  environment ArcaEnvironment
  serviceName String
  tokenValue  String?
  signValue   String?
  expiresAt   DateTime
  status      ArcaAuthSessionStatus @default(ACTIVE)
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt

  company     Company               @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId, environment, serviceName])
  @@index([expiresAt])
}

model ArcaRequestLog {
  id                String            @id @default(cuid())
  companyId         String
  invoiceId         String?
  requestType       ArcaRequestType
  environment       ArcaEnvironment
  endpointName      String?
  requestPayload    Json
  responsePayload   Json?
  httpStatus        Int?
  integrationResult IntegrationResult @default(UNKNOWN)
  errorCode         String?
  errorMessage      String?
  requestedAt       DateTime          @default(now())
  respondedAt       DateTime?

  company           Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  invoice           Invoice?          @relation(fields: [invoiceId], references: [id], onDelete: SetNull)

  @@index([companyId, requestedAt])
  @@index([invoiceId, requestedAt])
}

model GeneratedDocument {
  id               String                   @id @default(cuid())
  companyId        String
  invoiceId        String?
  documentType     GeneratedDocumentType
  storagePath      String
  mimeType         String
  fileSize         Int?
  checksum         String?
  generationStatus DocumentGenerationStatus @default(PENDING)
  generatedAt      DateTime?
  createdAt        DateTime                 @default(now())

  company          Company                  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  invoice          Invoice?                 @relation("InvoiceDocuments", fields: [invoiceId], references: [id], onDelete: SetNull)
  mainForInvoice   Invoice[]                @relation("InvoiceMainPdf")

  @@index([companyId, documentType])
  @@index([invoiceId])
}

